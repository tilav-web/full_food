generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CASHIER
  USER
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum OrderLocationSource {
  MINI_APP
  ADMIN_PANEL
}

enum OrderSource {
  MINI_APP
  CASHIER_PANEL
}

model User {
  id               String   @id @default(cuid())
  telegramId       String?  @unique
  telegramUsername String?
  isBotActive      Boolean  @default(false)
  phone            String   @unique
  password         String?
  refreshTokenHash String?
  firstName        String   @default("-")
  lastName         String   @default("-")
  role             Role     @default(USER)
  cartItems        CartItem[]
  orders           Order[]  @relation("CustomerOrders")
  createdOrders    Order[]  @relation("StaffCreatedOrders")
  createdBatches   InventoryBatch[] @relation("StaffCreatedBatches")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([role, createdAt])
  @@index([isBotActive])
}

model Category {
  id       String    @id @default(cuid())
  image    String
  name     String    @unique
  products Product[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  symbol    String   @unique
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  image         String
  name          String
  description   String
  price         Decimal
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  categoryId    String
  unitId        String
  category      Category @relation(fields: [categoryId], references: [id])
  unit          Unit     @relation(fields: [unitId], references: [id])
  cartItems     CartItem[]
  batches       InventoryBatch[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@index([unitId])
  @@index([stockQuantity])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model InventoryBatch {
  id               String   @id @default(cuid())
  productId        String
  quantity         Int
  receivedAt       DateTime
  createdByStaffId String?
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdByStaff   User?    @relation("StaffCreatedBatches", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([productId, receivedAt])
  @@index([createdByStaffId])
}

model Order {
  id                 String              @id @default(cuid())
  orderNumber        String              @unique
  userId             String?
  createdByStaffId   String?
  source             OrderSource         @default(MINI_APP)
  status             OrderStatus         @default(NEW)
  paymentStatus      PaymentStatus       @default(PENDING)
  locationSource     OrderLocationSource @default(MINI_APP)
  latitude           Float
  longitude          Float
  locationReceivedAt DateTime
  customerPhone      String
  customerFirstName  String
  customerLastName   String
  addressLine        String
  entrance           String?
  floor              String?
  apartment          String?
  note               String?
  cancelReason       String?
  subtotal           Decimal
  deliveryFee        Decimal             @default(0)
  totalPrice         Decimal
  user               User?               @relation("CustomerOrders", fields: [userId], references: [id], onDelete: SetNull)
  createdByStaff     User?               @relation("StaffCreatedOrders", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([createdByStaffId, createdAt])
  @@index([source, createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerPhone])
}

model OrderItem {
  id                 String   @id @default(cuid())
  orderId            String
  productId          String?
  productImage       String
  productName        String
  productDescription String
  categoryId         String?
  categoryImage      String
  categoryName       String
  unitPrice          Decimal
  quantity           Int
  lineTotal          Decimal
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}
