PORT=3000
DATABASE_URL="file:./dev.db"
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://full-food-seven.vercel.app
# Get this from @BotFather
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
BOT_POLLING_ENABLED=true
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
# Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-96-char-random-hex-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-another-96-char-random-hex-secret
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REFRESH_COOKIE_NAME=full_food_refresh_token
AUTH_REFRESH_COOKIE_MAX_AGE_MS=604800000
AUTH_REFRESH_COOKIE_SECURE=false
# Choose a long admin password, at least 16 chars
SEED_SUPER_ADMIN_PASSWORD=replace-with-strong-admin-password
